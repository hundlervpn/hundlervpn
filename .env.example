# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: Your Telegram Bot Token from @BotFather
# Required for generating Telegram Stars payment invoices
TELEGRAM_BOT_TOKEN=""

# OXAPAY_API_KEY: Your OxaPay Merchant API Key
# Required for cryptocurrency payments
OXAPAY_API_KEY=""

# PostgreSQL connection
# Public IP example: 5.42.118.215
# Domain example: c19ea5d2a5e6648aec8e5b4b.twc1.net
POSTGRESQL_HOST="5.42.118.215"
POSTGRESQL_PORT="5432"
POSTGRESQL_USER="gen_user"
POSTGRESQL_PASSWORD=""
POSTGRESQL_DBNAME="default_db"

# SSL mode for PostgreSQL connection:
# - disable: for private network connection
# - require: for domain + certificate connection
POSTGRESQL_SSL_MODE="disable"

# Optional path to CA certificate (used when POSTGRESQL_SSL_MODE=require)
# Windows example: C:\\Users\\<username>\\.cloud-certs\\root.crt
POSTGRESQL_SSL_CA_PATH=""

# XRAY / VLESS REALITY (used to generate user connection keys after payment)
XRAY_VLESS_HOST="72.56.1.62"
XRAY_VLESS_PORT="443"
XRAY_REALITY_PUBLIC_KEY="_PC1kC32o9GwE9jfh7FlNl_ybyqEEypVlif3lSwNsjc"
XRAY_REALITY_SNI="www.microsoft.com"
XRAY_REALITY_SHORT_ID="2d743c4977110a0b"
XRAY_REALITY_FINGERPRINT="chrome"
XRAY_VLESS_FLOW="xtls-rprx-vision"
XRAY_VLESS_REMARK="HundlerVPN"
# Country code (ISO 3166-1 alpha-2) for flag emoji in VPN client (e.g. NL, DE, US, FI)
XRAY_VLESS_COUNTRY="NL"
XRAY_SYNC_TOKEN="2df54d60052bb1d4821647215b91c7bfa78a542b338c0d3b"

# Telegram bot username for referral links in UI (without @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="hundlervpn_bot"

# SMTP settings for email auth (passwordless login)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""